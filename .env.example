# PHI Firewall does not require environment variables for local browser inference.
# The browser downloads public model artifacts from Hugging Face and runs inference with WebGPU.

# Optional: used by Hugging Face CLI/Python tooling when preparing data or pushing models.
# Prefer `huggingface-cli login` or `huggingface_hub.login()` for local development.
HF_TOKEN=

# Optional: default Hugging Face repos for training utilities.
# Set these before using `npm run prepare:data:push`, `npm run export:model:push`,
# or benchmarking private/custom model repos.
PHI_FIREWALL_HF_DATASET_REPO=your-org/phi-redaction-sft
PHI_FIREWALL_HF_MODEL_REPO=your-org/phi-firewall-lfm2-350m-onnx

# Optional: Modal is usually configured with `modal setup`.
# Keep Modal credentials out of git if you export them manually in your shell.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
