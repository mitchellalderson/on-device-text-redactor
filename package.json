{
  "name": "phi-firewall",
  "private": true,
  "version": "0.0.0",
  "description": "Browser-based PHI redaction demo that runs LFM2 ONNX inference locally with WebGPU.",
  "author": "Mitchell Alderson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/mitchellalderson/on-device-text-redactor.git"
  },
  "bugs": {
    "url": "https://github.com/mitchellalderson/on-device-text-redactor/issues"
  },
  "homepage": "https://github.com/mitchellalderson/on-device-text-redactor#readme",
  "keywords": [
    "phi",
    "pii",
    "redaction",
    "webgpu",
    "onnx",
    "svelte",
    "huggingface",
    "modal"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "deploy": "npm run build && modal deploy serve.py",
    "train": "cd training/leap-finetune && uv run leap-finetune ../config.yaml",
    "train:logs": "modal app logs phi-firewall-finetune",
    "prepare:data": "training/leap-finetune/.venv/bin/python training/prepare_data.py --no-push",
    "prepare:data:push": "training/leap-finetune/.venv/bin/python training/prepare_data.py --push",
    "export:model": "training/leap-finetune/.venv/bin/python training/export.py --lora-path training/output/lora --output-path training/output/merged --export-onnx",
    "export:model:push": "training/leap-finetune/.venv/bin/python training/export.py --lora-path training/output/lora --output-path training/output/merged --export-onnx --push-to-hub",
    "benchmark": "training/leap-finetune/.venv/bin/modal run benchmark.py"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.3",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "onnxruntime-web": "^1.26.0"
  }
}
